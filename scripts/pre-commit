#!/bin/bash
# Pre-commit hook for my-skills (tracked template — copy to .git/hooks/pre-commit to activate)
# Enforces structure validation and catalog freshness before every commit
#
# Installation:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "[pre-commit] Running structure validation..."
if ! python3 scripts/verify_structure.py; then
    echo "[pre-commit] FAILED: Structure validation failed. Commit aborted."
    exit 1
fi

echo "[pre-commit] Running catalog generation..."
if ! python3 scripts/generate_skills_catalog.py; then
    echo "[pre-commit] FAILED: Catalog generation failed. Commit aborted."
    exit 1
fi

# Check if catalog files were updated and stage them
git diff --quiet SKILLS.md docs/full-catalog.md README.md
if [ $? -ne 0 ]; then
    echo "[pre-commit] Catalog files updated — staging auto-generated changes..."
    git add SKILLS.md docs/full-catalog.md README.md
fi

echo "[pre-commit] All checks passed. Proceeding with commit."
exit 0
