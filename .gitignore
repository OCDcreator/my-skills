.DS_Store
.tmp-skills/
__pycache__/
*.pyc

# Local secrets and API credentials
**/.env
**/.env.*

automation/runtime/
custom/knowledge-to-print-html/artifacts/
custom/knowledge-to-print-html/evals/
custom/knowledge-to-print-html/.local-libs/
custom/knowledge-to-print-html/.local-qpdf/
custom/knowledge-to-print-html/.venv-print/

# pdf-toc-bookmarker runtime job artifacts (real-book OCR data, per-user, not part of the skill)
custom/pdf-toc-bookmarker/work/

# Syncthing transient and conflict files
~syncthing~*.tmp
.syncthing.*.tmp
*.sync-conflict-*
.stfolder/

# Windows NUL device name accidentally materialized as a file under Git Bash
# (e.g. `cmd ... > nul` or `2>nul` creates a literal file named `nul` instead
# of discarding output). These are never intentional; ignore and prevent.
nul
.stversions/
automation/**/__pycache__/
automation/**/*.pyc

# Superpowers specs/plans are local working docs, not part of the repo
docs/superpowers/

# skill-evolution pre-edit snapshots
custom/**/SKILL.md.bak-*
custom/**/*.bak-*
custom/**/*.bak-*.*
