{
  "name": "synthetic-plugin-rich-health",
  "description": "Synthetic plugin-neutral fixture covering rich generic assertions and non-blocking severities.",
  "assertions": [
    {
      "id": "scenario-open-view",
      "type": "scenario-success"
    },
    {
      "id": "plugin-root-count",
      "type": "dom-count",
      "selector": ".plugin-root",
      "min": 1,
      "severity": "fail"
    },
    {
      "id": "plugin-root-visible",
      "type": "dom-visible",
      "selector": ".plugin-root",
      "min": 1,
      "severity": "fail"
    },
    {
      "id": "plugin-status-text",
      "type": "dom-text-regex",
      "selector": ".plugin-root",
      "pattern": "Ready|Healthy",
      "flags": "i",
      "severity": "fail"
    },
    {
      "id": "plugin-ready-attribute",
      "type": "dom-attribute",
      "selector": ".plugin-root",
      "attribute": "data-ready-state",
      "expected": "ready",
      "severity": "warn"
    },
    {
      "id": "plugin-display-style",
      "type": "computed-style",
      "selector": ".plugin-root",
      "property": "display",
      "expected": "block",
      "severity": "warn"
    },
    {
      "id": "grouped-log-health",
      "type": "log-group",
      "severity": "fail",
      "rules": [
        {
          "id": "plugin-ready-log",
          "type": "contains",
          "value": "Plugin ready",
          "source": "combined"
        },
        {
          "id": "no-fatal-errors",
          "type": "count",
          "pattern": "\\b(?:error|unhandled)\\b",
          "flags": "gi",
          "source": "combined",
          "max": 0
        }
      ]
    },
    {
      "id": "view-open-budget",
      "type": "timing-budget",
      "metric": "viewOpenCompletedMs",
      "maxMs": 1200,
      "severity": "warn"
    },
    {
      "id": "cold-start-empty-state",
      "type": "dom-text-regex",
      "selector": ".plugin-empty-state",
      "pattern": "Loading data",
      "flags": "i",
      "severity": "expected"
    },
    {
      "id": "server-ready-budget",
      "type": "timing-budget",
      "metric": "serverReadyMs",
      "maxMs": 500,
      "severity": "flaky"
    }
  ]
}
