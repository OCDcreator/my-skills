{
  "name": "plugin-view-health-template",
  "description": "Plugin-agnostic rich assertion template covering DOM counts/visibility/text, attributes/styles, grouped log rules, and timing budgets.",
  "assertions": [
    {
      "id": "scenario-open-view",
      "type": "scenario-success"
    },
    {
      "id": "screenshot-exists",
      "type": "artifact-exists",
      "field": "screenshot"
    },
    {
      "id": "dom-exists",
      "type": "artifact-exists",
      "field": "dom"
    },
    {
      "id": "plugin-root-count",
      "type": "dom-count",
      "selector": "<plugin-root-selector>",
      "min": 1,
      "severity": "fail"
    },
    {
      "id": "plugin-root-visible",
      "type": "dom-visible",
      "selector": "<plugin-root-selector>",
      "min": 1,
      "severity": "fail"
    },
    {
      "id": "plugin-status-text",
      "type": "dom-text-regex",
      "selector": "<plugin-root-selector>",
      "pattern": "<expected-heading-or-status-regex>",
      "flags": "i",
      "severity": "fail"
    },
    {
      "id": "plugin-ready-attribute",
      "type": "dom-attribute",
      "selector": "<plugin-root-selector>",
      "attribute": "data-ready-state",
      "expected": "ready",
      "severity": "warn"
    },
    {
      "id": "plugin-display-style",
      "type": "computed-style",
      "selector": "<plugin-root-selector>",
      "property": "display",
      "expected": "block",
      "severity": "warn"
    },
    {
      "id": "grouped-log-health",
      "type": "log-group",
      "severity": "fail",
      "rules": [
        {
          "id": "no-fatal-banner",
          "type": "not-contains",
          "value": "<known-fatal-error-substring>",
          "source": "combined"
        },
        {
          "id": "error-count-budget",
          "type": "count",
          "pattern": "\\b(?:error|unhandled)\\b",
          "flags": "gi",
          "source": "combined",
          "max": 0
        }
      ]
    },
    {
      "id": "view-open-budget",
      "type": "timing-budget",
      "metric": "viewOpenCompletedMs",
      "maxMs": 1500,
      "severity": "warn"
    },
    {
      "id": "cold-start-empty-state-allowed",
      "type": "dom-text-regex",
      "selector": "<plugin-empty-state-selector>",
      "pattern": "<known-empty-state-regex>",
      "flags": "i",
      "severity": "expected"
    },
    {
      "id": "server-ready-flaky-budget",
      "type": "timing-budget",
      "metric": "serverReadyMs",
      "maxMs": 5000,
      "allowMissing": true,
      "severity": "flaky"
    }
  ]
}
