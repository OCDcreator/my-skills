{
  "name": "opencodian-slash-view-health",
  "description": "OpenCodian view health assertions for slash autocomplete deployment validation.",
  "assertions": [
    {
      "id": "scenario-open-view",
      "type": "scenario-success"
    },
    {
      "id": "screenshot-exists",
      "type": "artifact-exists",
      "field": "screenshot"
    },
    {
      "id": "dom-exists",
      "type": "artifact-exists",
      "field": "dom"
    },
    {
      "id": "dom-has-opencodian-view",
      "type": "dom-contains",
      "value": "OpenCodian"
    },
    {
      "id": "no-session-404",
      "type": "log-not-contains",
      "value": "Request failed, status 404"
    }
  ]
}
