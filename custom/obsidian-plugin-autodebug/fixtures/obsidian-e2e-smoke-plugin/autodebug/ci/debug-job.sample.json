{
  "version": 1,
  "job": {
    "id": "obsidian-e2e-smoke",
    "label": "Obsidian E2E smoke dry-run"
  },
  "runtime": {
    "cwd": ".",
    "pluginId": "obsidian-e2e-smoke-plugin",
    "testVaultPluginDir": "test-vault/.obsidian/plugins/obsidian-e2e-smoke-plugin",
    "obsidianCommand": "obsidian",
    "outputDir": ".obsidian-debug/{{jobId}}-{{platform}}"
  },
  "build": {
    "enabled": true,
    "command": [
      "npm",
      "run",
      "build"
    ]
  },
  "deploy": {
    "enabled": true,
    "from": "dist"
  },
  "bootstrap": {
    "enabled": false
  },
  "reload": {
    "enabled": false
  },
  "logWatch": {
    "enabled": false
  },
  "scenario": {
    "enabled": false
  },
  "assertions": {
    "path": "",
    "domSelector": "",
    "domText": false
  },
  "comparison": {
    "baselineDiagnosisPath": ""
  },
  "profile": {
    "enabled": false
  },
  "report": {
    "enabled": false
  },
  "capture": {
    "screenshot": false,
    "dom": false
  },
  "state": {
    "restoreAfterRun": false
  }
}
