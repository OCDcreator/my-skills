{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/obsidian-plugin-autodebug/obsidian-debug-job.schema.json",
  "title": "Obsidian Plugin Autodebug Job",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "job",
    "runtime"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "job": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable job id used for output folders and reports."
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": [
        "pluginId",
        "testVaultPluginDir"
      ],
      "properties": {
        "cwd": {
          "type": "string",
          "description": "Plugin repository working directory."
        },
        "pluginId": {
          "type": "string"
        },
        "testVaultPluginDir": {
          "type": "string"
        },
        "vaultName": {
          "type": "string"
        },
        "obsidianCommand": {
          "type": "string"
        },
        "outputDir": {
          "type": "string",
          "description": "Output directory. Supports {{jobId}} and {{platform}}."
        }
      }
    },
    "build": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "command": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "deploy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "from": {
          "type": "string"
        }
      }
    },
    "reload": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "enum": [
            "cli",
            "cdp"
          ]
        },
        "useCdp": {
          "type": "boolean"
        },
        "cdp": {
          "type": "object"
        }
      }
    },
    "logWatch": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "seconds": {
          "type": "integer",
          "minimum": 0
        },
        "pollIntervalMs": {
          "type": "integer",
          "minimum": 50
        },
        "consoleLimit": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "scenario": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "commandId": {
          "type": "string"
        },
        "sleepMs": {
          "type": "integer"
        }
      }
    },
    "assertions": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "domSelector": {
          "type": "string"
        },
        "domText": {
          "type": "boolean"
        }
      }
    },
    "comparison": {
      "type": "object",
      "properties": {
        "baselineDiagnosisPath": {
          "type": "string"
        }
      }
    },
    "profile": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "runs": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "rootOutput": {
          "type": "string"
        }
      }
    },
    "report": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "diagnosis": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "comparison": {
          "type": "string"
        },
        "output": {
          "type": "string"
        }
      }
    },
    "state": {
      "type": "object",
      "properties": {
        "restoreAfterRun": {
          "type": "boolean"
        },
        "vaultSnapshot": {
          "type": "object"
        },
        "pluginReset": {
          "type": "object"
        }
      }
    }
  }
}
