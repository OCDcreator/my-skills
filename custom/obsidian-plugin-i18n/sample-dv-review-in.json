  "entries": [
    {
      "id": "0",
      "method": "setDesc",
      "original": "Enable or disable executing regular inline Dataview queries.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "1",
      "method": "setDesc",
      "original": "Enable or disable executing DataviewJS queries.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "2",
      "method": "setDesc",
      "original": "Enable or disable executing inline DataviewJS queries. Requires that DataviewJS queries are enabled.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "3",
      "method": "setDesc",
      "original": "Enables or disables visual highlighting / pretty rendering for inline fields in reading view.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "4",
      "method": "setDesc",
      "original": "Enables or disables visual highlighting / pretty rendering for inline fields in Live Preview.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "5",
      "method": "setDesc",
      "original": "Keyword for DataviewJS blocks. Defaults to 'dataviewjs'. Reload required for changes to take effect.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "6",
      "method": "setDesc",
      "original": "The prefix to inline queries (to mark them as Dataview queries). Defaults to '='.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "7",
      "method": "setDesc",
      "original": "The prefix to JavaScript inline queries (to mark them as DataviewJS queries). Defaults to '$='.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "8",
      "method": "setDesc",
      "original": "If enabled, inline queries will also be evaluated inside full code blocks.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "9",
      "method": "setDesc",
      "original": "If toggled off, the small number in the result header of TASK and TABLE queries will be hidden.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "10",
      "method": "setDesc",
      "original": "If set, queries which return 0 results will render a warning message.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "11",
      "method": "setDesc",
      "original": "What null/non-existent should show up as in tables, by default. This supports Markdown notation.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "12",
      "method": "setDesc",
      "original": "If enabled, views will automatically refresh when files in your vault change; this can negatively affect",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "13",
      "method": "setDesc",
      "original": "How long to wait (in milliseconds) for files to stop changing before updating views.",
      "translation": "",
      "context": "",
      "defaultEnabled": true
    },
    {
      "id": "14",
      "method": "setDesc",
      "original": "The default date format (see Luxon date format options).",
